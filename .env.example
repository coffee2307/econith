# =============================================================================
# ECONITH :: environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env.
#   cp .env.example .env
# =============================================================================

# --- Application -------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Binance API (three sovereign credential groups) -------------------------
# Binance splits demo (testnet) and live (mainnet) — keys are NOT interchangeable.
#
# 1) BINANCE_DATA_API_*     — market data / websocket collectors (mainnet public OK)
# 2) BINANCE_DEMO_API_*     — demo / testnet trading (spot or futures testnet)
# 3) BINANCE_TRADE_API_*    — live mainnet trading ONLY
#
# Legacy BINANCE_API_KEY/SECRET still work as fallback.
# BINANCE_EXECUTION_ENV=demo|live picks which trade key pair CCXT uses.
# BINANCE_TESTNET is deprecated; maps to demo/live when EXECUTION_ENV is unset.

# --- 1) Data plane (market feeds) --------------------------------------------
BINANCE_DATA_API_KEY=your_binance_data_api_key_here
BINANCE_DATA_API_SECRET=your_binance_data_api_secret_here
BINANCE_DATA_REST_BASE_URL=https://api.binance.com
BINANCE_DATA_WS_BASE_URL=wss://stream.binance.com:9443/ws

# --- 2) Demo plane (futures testnet / paper trading) -------------------------
# Futures testnet keys (required for Quant desk): https://testnet.binancefuture.com/
# Spot testnet (optional, separate keys): https://testnet.binance.vision/
BINANCE_DEMO_API_KEY=your_binance_futures_demo_api_key_here
BINANCE_DEMO_API_SECRET=your_binance_futures_demo_api_secret_here
BINANCE_DEMO_REST_BASE_URL=https://testnet.binancefuture.com
BINANCE_DEMO_WS_BASE_URL=wss://fstream.binancefuture.com

# --- 3) Live plane (mainnet USDT-M futures) ----------------------------------
BINANCE_TRADE_API_KEY=your_binance_live_trade_api_key_here
BINANCE_TRADE_API_SECRET=your_binance_live_trade_api_secret_here
BINANCE_TRADE_REST_BASE_URL=https://fapi.binance.com
BINANCE_TRADE_WS_BASE_URL=wss://fstream.binance.com

# Execution routing: demo uses DEMO keys + CCXT sandbox; live uses TRADE keys.
BINANCE_EXECUTION_ENV=demo
BINANCE_CCXT_DEFAULT_TYPE=future
# future / swap = USDT-M perps. spot = spot testnet (separate keys at binance.vision).
BINANCE_TESTNET=true
# Legacy aliases (optional; split URLs above are preferred)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_REST_BASE_URL=https://testnet.binancefuture.com
BINANCE_WS_BASE_URL=wss://fstream.binancefuture.com
# CCXT connects on backend startup when quant mode = REALITY and ccxt is installed.

# --- AI execution sizing + Sentinel (dev-friendly defaults) ------------------
SENTINEL_LATENCY_LIMIT_MS=2000.0
AI_MIN_EXPOSURE_DELTA=0.002
AI_CONFIDENCE_FLOOR=0.12
AI_BASE_NOTIONAL_USD=2000.0
AI_MIN_LEG_NOTIONAL_USD=30.0

# --- Macro ingestion (CORE, zero-cost topology) ------------------------------
# St. Louis Fed FRED API key (free registration at fred.stlouisfed.org).
# This is the ONLY keyed macro source; World Bank, IMF, Eurostat and yfinance
# are keyless/open-access and require no configuration.
FRED_API_KEY=your_fred_api_key_here

# --- Storage -----------------------------------------------------------------
# Primary DSN. If unreachable at startup the runtime probes it (SELECT 1, 5s)
# and fails over automatically to a local sqlite:///econith_fallback.db matrix.
DATABASE_URL=postgresql://econith:econith@postgres:5432/econith
REDIS_URL=redis://redis:6379/0

# --- Sentinel risk governance ------------------------------------------------
# Tunable thresholds. Defaults are relaxed for local dev.
# Tighten for production (e.g. SENTINEL_LATENCY_LIMIT_MS=300, MAX_DRAWDOWN=0.03).
SENTINEL_MAX_DRAWDOWN_PCT=0.10
SENTINEL_VAR_LIMIT_PCT=0.15
SENTINEL_FREEZE_COOLDOWN_S=30.0

# --- Execution / capital -----------------------------------------------------
# Principal equity base shared 1:1 by the Cockpit Fuel Gauge, the Sentinel risk
# governor, and the simulation runners.
STARTING_CAPITAL=100000.0

# --- API security ------------------------------------------------------------
# When true, sensitive mutating routes (/mode, /world/tariff, /world/mutate,
# /world/scenario, /sentinel/*, /time/*, /order*) require a credential presented
# as `X-API-Key: <key>` or `Authorization: Bearer <key>`.
API_AUTH_ENABLED=false
# Comma-separated accepted keys/tokens, e.g. API_KEYS=key1,key2
API_KEYS=
# Rotating audit trail for every operator state-mutation command.
AUDIT_LOG_PATH=logs/econith_audit.log
AUDIT_LOG_MAX_BYTES=5000000
AUDIT_LOG_BACKUPS=5

# --- Frontend (browser-side; resolved from the HOST, hence localhost) --------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/stream/metrics
NEXT_PUBLIC_SOCIAL_UI_URL=http://localhost:3001

# --- econith_social (first-party social simulation sidecar) ------------------
# GRAPH_BACKEND=local runs without Zep (JSON graphs on disk). Use zep only if you set ZEP_API_KEY.
GRAPH_BACKEND=local
# When backend_core runs in Docker and social runs on the host, use host.docker.internal
SOCIAL_API_URL=http://localhost:5001
# SOCIAL_API_URL=http://host.docker.internal:5001
SOCIAL_UI_URL=http://localhost:3001
# Groq (OpenAI-compatible): https://console.groq.com/docs/openai
# Comma-separated keys — when one hits rate limit / quota, the next key is used automatically.
# Example: LLM_API_KEY=gsk_key_one,gsk_key_two,gsk_key_three
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile
# ZEP_API_KEY=   # optional; only if GRAPH_BACKEND=zep

# --- Operational alerts (Telegram) -------------------------------------------
# Required for AlertDispatcher. Get token from @BotFather; chat id from @userinfobot.
TELEGRAM_BOT_API_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# ALERT_ENABLED=true
# ALERT_MIN_INTERVAL_S=60
# ALERT_SERVICE_NAME=ECONITH
